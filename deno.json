{
    "workspace": [
        "./packages/*",
        "./examples/*"
    ],
    "compilerOptions": {
        "strict": true,
        "noUncheckedIndexedAccess": true
    },
    "lint": {
        "rules": {
            "tags": [
                "recommended"
            ]
        }
    },
    "fmt": {
        "lineWidth": 100,
        "indentWidth": 2,
        "semiColons": true,
        "singleQuote": false
    },
    "tasks": {
        "check": "deno check **/*.ts",
        "dev:example-hono-basic": "deno task --filter @saurbit/example-hono-basic dev",
        "lint": "deno lint",
        "fmt": "deno fmt",
        "fmt:check": "deno fmt --check",
        "test": "deno test --parallel"
    }
}