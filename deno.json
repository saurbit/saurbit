{
  "workspace": [
    "./packages/*",
    "./examples/*"
  ],
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "tasks": {
    "build:npm": "deno task --filter @saurbit/oauth2 build:npm && deno task --filter @saurbit/hono-oauth2 build:npm",
    "check": "deno task --filter @saurbit/ check",
    "dev:example-hono-basic": "deno task --filter @saurbit/example-hono-basic dev",
    "dev:example-oak-basic": "deno task --filter @saurbit/example-oak-basic dev",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "test": "deno test --parallel"
  }
}
